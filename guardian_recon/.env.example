# GuardianRecon — نموذج متغيرات البيئة
# ==========================================
# انسخ هذا الملف باسم .env وعبّي القيم الحقيقية.
# ملف .env نفسه مستثنى من git تلقائياً (.gitignore) — لا يترفع أبداً.
#
# نفس هذي الأسماء بالضبط تُستخدم كـ GitHub Secrets في الإنتاج/CI.

# --- الاتصال بـ Odoo (إلزامي لتشغيل التسوية على بيانات حقيقية) ---
ODOO_HOST=mycompany.odoo.com
ODOO_PORT=443
ODOO_PROTOCOL=jsonrpc+ssl
ODOO_DB=mycompany-prod
ODOO_USER=your-email@example.com
ODOO_PASSWORD=your-api-key-or-password

# --- قاعدة بيانات GuardianRecon نفسها (اختياري، افتراضياً SQLite محلي) ---
# GUARDIAN_DB_URL=postgresql://user:pass@host:5432/guardian_recon
